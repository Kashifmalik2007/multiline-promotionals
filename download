<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | Multiline Promotional</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Montserrat',sans-serif;background:#2e3092;color:#fff;min-height:100vh}
    .sidebar{width:250px;background:#252878;height:100vh;position:fixed;top:0;left:0;display:flex;flex-direction:column;z-index:100}
    .sidebar-logo{padding:24px 20px;border-bottom:1px solid #3d41a8}
    .sidebar-logo .brand{color:#f5811e;font-size:0.85rem;font-weight:800;letter-spacing:1px}
    .sidebar-logo .sub{color:#a0a3c4;font-size:0.65rem;letter-spacing:1px}
    .sidebar-nav{padding:20px 0;flex:1}
    .nav-item{display:flex;align-items:center;gap:12px;padding:12px 20px;color:#a0a3c4;text-decoration:none;font-size:0.85rem;font-weight:600;transition:all 0.2s}
    .nav-item:hover,.nav-item.active{background:#2e3092;color:#f5811e;border-left:3px solid #f5811e}
    .nav-item i{width:18px}
    .sidebar-footer{padding:16px 20px;border-top:1px solid #3d41a8}
    .sidebar-footer a{display:flex;align-items:center;gap:10px;color:#a0a3c4;text-decoration:none;font-size:0.8rem}
    .sidebar-footer a:hover{color:#f5811e}
    .main-content{margin-left:250px;padding:24px;min-height:100vh}
    .top-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px}
    .top-bar h1{font-size:1.4rem;font-weight:700}
    .top-bar .user-info{color:#a0a3c4;font-size:0.85rem}
    .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px}
    .stat-card{background:#252878;border-radius:10px;padding:20px;border-left:4px solid #f5811e}
    .stat-card h3{font-size:2rem;font-weight:800;color:#f5811e}
    .stat-card p{color:#a0a3c4;font-size:0.8rem;margin-top:4px}
    .card{background:#252878;border-radius:10px;padding:24px;margin-bottom:24px}
    .card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
    .card-header h2{font-size:1.1rem;font-weight:700}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:10px 18px;border-radius:8px;font-size:0.85rem;font-weight:600;cursor:pointer;text-decoration:none;border:none;transition:all 0.2s}
    .btn-primary{background:#f5811e;color:#000}
    .btn-primary:hover{background:#e0700f}
    .btn-danger{background:#dc3545;color:#fff}
    .btn-danger:hover{background:#c82333}
    .btn-edit{background:#3d41a8;color:#fff}
    .btn-edit:hover{background:#3d5270}
    .btn-sm{padding:6px 12px;font-size:0.78rem}
    table{width:100%;border-collapse:collapse}
    th{background:#2e3092;color:#a0a3c4;font-size:0.75rem;letter-spacing:0.5px;padding:10px 14px;text-align:left;text-transform:uppercase}
    td{padding:12px 14px;border-bottom:1px solid #2e3092;font-size:0.85rem;vertical-align:middle}
    tr:hover td{background:#2e309290}
    .badge-cat{background:#2e3092;color:#f5811e;padding:3px 8px;border-radius:4px;font-size:0.72rem;font-weight:700}
    .badge-featured{background:#f5811e;color:#000;padding:3px 8px;border-radius:4px;font-size:0.72rem;font-weight:700}
    .badge-no{background:#3d41a8;color:#a0a3c4;padding:3px 8px;border-radius:4px;font-size:0.72rem}
    .product-thumb{width:50px;height:50px;object-fit:cover;border-radius:6px;background:#2e3092}
    .product-thumb-placeholder{width:50px;height:50px;background:#2e3092;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#3d41a8}
    .actions{display:flex;gap:8px}
    .flash{padding:12px 16px;border-radius:8px;margin-bottom:20px;font-size:0.85rem}
    .flash-success{background:#00c85122;border:1px solid #00c851;color:#00c851}
    .flash-error{background:#dc354522;border:1px solid #dc3545;color:#dc3545}
    .modal-overlay{display:none;position:fixed;inset:0;background:#00000088;z-index:200;align-items:center;justify-content:center}
    .modal-overlay.show{display:flex}
    .modal{background:#252878;border-radius:12px;padding:28px;max-width:400px;width:90%}
    .modal h3{margin-bottom:12px}
    .modal p{color:#a0a3c4;font-size:0.9rem;margin-bottom:20px}
    .modal-actions{display:flex;gap:12px;justify-content:flex-end}
    .form-group{margin-bottom:16px}
    .form-group label{display:block;color:#a0a3c4;font-size:0.78rem;font-weight:600;margin-bottom:6px;letter-spacing:0.5px}
    .form-group input{width:100%;padding:10px 14px;background:#2e3092;border:1px solid #3d41a8;border-radius:8px;color:#fff;font-size:0.85rem;outline:none}
    .form-group input:focus{border-color:#f5811e}
    @media(max-width:768px){.stats-grid{grid-template-columns:repeat(2,1fr)}.sidebar{display:none}.main-content{margin-left:0}}
  </style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <div class="sidebar-logo">
    <div class="brand">MULTILINE PROMOTIONAL</div>
    <div class="sub">ADMIN PANEL</div>
  </div>
  <nav class="sidebar-nav">
    <a href="/admin/dashboard" class="nav-item active"><i class="fas fa-th-large"></i> Dashboard</a>
    <a href="/admin/products/new" class="nav-item"><i class="fas fa-plus-circle"></i> Add Product</a>
    <a href="/catalog" target="_blank" class="nav-item"><i class="fas fa-store"></i> View Store</a>
    <a href="/contact" target="_blank" class="nav-item"><i class="fas fa-envelope"></i> Contact Page</a>
  </nav>
  <div class="sidebar-footer">
    <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </div>
</div>

<!-- MAIN -->
<div class="main-content">
  <div class="top-bar">
    <h1>Dashboard</h1>
    <div class="user-info">Welcome, <strong style="color:#f5811e"><%= admin.username %></strong></div>
  </div>

  <% if (typeof success !== 'undefined' && success.length > 0) { %>
  <div class="flash flash-success"><i class="fas fa-check-circle"></i> <%= success[0] %></div>
  <% } %>
  <% if (typeof error !== 'undefined' && error.length > 0) { %>
  <div class="flash flash-error"><i class="fas fa-exclamation-circle"></i> <%= error[0] %></div>
  <% } %>

  <!-- STATS -->
  <div class="stats-grid">
    <div class="stat-card">
      <h3><%= stats.total %></h3>
      <p><i class="fas fa-box"></i> Total Products</p>
    </div>
    <div class="stat-card">
      <h3><%= stats.featured %></h3>
      <p><i class="fas fa-star"></i> Featured</p>
    </div>
    <div class="stat-card">
      <h3><%= stats.categories %></h3>
      <p><i class="fas fa-tags"></i> Categories</p>
    </div>
    <div class="stat-card">
      <h3>5.0</h3>
      <p><i class="fas fa-star"></i> Rating</p>
    </div>
  </div>

  <!-- PRODUCTS TABLE -->
  <div class="card">
    <div class="card-header">
      <h2>All Products</h2>
      <a href="/admin/products/new" class="btn btn-primary"><i class="fas fa-plus"></i> Add Product</a>
    </div>
    <div style="overflow-x:auto">
      <table>
        <thead>
          <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Category</th>
            <th>MOQ</th>
            <th>Featured</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(p => { %>
          <tr>
            <td>
              <% if (p.image && p.image !== '/images/placeholder.jpg') { %>
              <img src="<%= p.image %>" alt="<%= p.name %>" class="product-thumb">
              <% } else { %>
              <div class="product-thumb-placeholder"><i class="fas fa-image"></i></div>
              <% } %>
            </td>
            <td><strong><%= p.name %></strong></td>
            <td><span class="badge-cat"><%= p.category %></span></td>
            <td><%= p.moq %></td>
            <td>
              <% if (p.featured) { %>
              <span class="badge-featured">YES</span>
              <% } else { %>
              <span class="badge-no">NO</span>
              <% } %>
            </td>
            <td>
              <div class="actions">
                <a href="/product/<%= p.id %>" target="_blank" class="btn btn-edit btn-sm"><i class="fas fa-eye"></i></a>
                <a href="/admin/products/<%= p.id %>/edit" class="btn btn-primary btn-sm"><i class="fas fa-edit"></i></a>
                <button class="btn btn-danger btn-sm" onclick="confirmDelete('<%= p.id %>', '<%= p.name %>')"><i class="fas fa-trash"></i></button>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- CHANGE PASSWORD -->
  <div class="card">
    <div class="card-header">
      <h2>Change Password</h2>
    </div>
    <form action="/admin/change-password" method="POST" style="max-width:400px">
      <div class="form-group">
        <label>CURRENT PASSWORD</label>
        <input type="password" name="currentPassword" required>
      </div>
      <div class="form-group">
        <label>NEW PASSWORD</label>
        <input type="password" name="newPassword" required minlength="6">
      </div>
      <div class="form-group">
        <label>CONFIRM NEW PASSWORD</label>
        <input type="password" name="confirmPassword" required minlength="6">
      </div>
      <button type="submit" class="btn btn-primary"><i class="fas fa-key"></i> Update Password</button>
    </form>
  </div>
</div>

<!-- DELETE MODAL -->
<div class="modal-overlay" id="deleteModal">
  <div class="modal">
    <h3>Delete Product</h3>
    <p id="deleteText">Are you sure you want to delete this product? This action cannot be undone.</p>
    <div class="modal-actions">
      <button class="btn btn-edit" onclick="closeModal()">Cancel</button>
      <form id="deleteForm" method="POST">
        <input type="hidden" name="_method" value="DELETE">
        <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Delete</button>
      </form>
    </div>
  </div>
</div>

<script>
function confirmDelete(id, name) {
  document.getElementById('deleteText').textContent = 'Delete "' + name + '"? This cannot be undone.';
  document.getElementById('deleteForm').action = '/admin/products/' + id;
  document.getElementById('deleteModal').classList.add('show');
}
function closeModal() {
  document.getElementById('deleteModal').classList.remove('show');
}
</script>
</body>
</html>
